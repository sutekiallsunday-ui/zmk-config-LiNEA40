#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>

#define MOUSE 1
#define MARK 2
#define CURSOR 3
#define FUNCTION 4
#define SCROLL 5
#define WIRELESS 6

&mt {
    flavor = "balanced";
    quick-tap-ms = <0>;
};

/ {
    combos {
        compatible = "zmk,combos";

        ZenkakuHankaku {
            bindings = <&kp GRAVE>;
            key-positions = <40 41>;
        };

        DeleteKey {
            bindings = <&kp DEL>;
            key-positions = <20 21>;
        };
    };

    macros {
        macro01: macro01 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LS(I) &kp LS(Q) &kp LS(V) &kp LS(I) &kp LS(A)>;
            label = "MACRO01";
        };

        macro02: macro02 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LS(C) &kp LS(S) &kp LS(M) &kp LS(S)>;
            label = "MACRO02";
        };

        macro03: macro03 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LS(M) &kp E &kp D &kp LS(T) &kp E &kp C &kp H &kp KP_NUMBER_2>;
            label = "MACRO03";
        };

        macro04: macro04 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LS(A) &kp LS(S) &kp SPACE &kp LS(C) &kp O &kp N &kp N &kp E &kp C &kp T>;
            label = "MACRO04";
        };

        macro05: macro05 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LS(S) &kp LS(H) &kp LS(D) &kp SPACE &kp LS(E) &kp C &kp H &kp O &kp SPACE &kp LS(L) &kp A &kp B &kp DOT>;
            label = "MACRO05";
        };

        macro06: macro06 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp KP_NUMBER_1 &kp O &kp N &kp KP_NUMBER_1>;
            label = "MACRO06";
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
&kp ESC     &mt LEFT_ALT Q      &kp W          &kp E         &kp R               &kp T          &kp Y      &kp U            &kp I      &kp O    &kp P                    &kp DEL    &kp BSPC
&kp TAB     &mt LEFT_SHIFT A    &kp S          &kp D         &kp F               &kp G          &kp H      &kp J            &kp K      &kp L    &mt RIGHT_SHIFT MINUS    &kp ENTER
&kp LSHIFT  &mt LEFT_CONTROL Z  &kp X          &kp C         &kp V               &kp B          &kp N      &kp M            &kp COMMA  &kp DOT  &mt RIGHT_CONTROL QMARK  &kp RSHIFT
                                &mt LCTRL ESC  &kp LEFT_WIN  &mt LEFT_ALT GRAVE  &lt 4 SPACE    &lt 3 ENTER
            >;
        };

        MOUSE {
            bindings = <
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans    &trans    &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &mkp MB1  &mkp MB2  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans    &trans    &trans  &trans  &trans
                &trans  &trans  &trans  &trans  &trans
            >;
        };

        MARK {
            bindings = <
&trans  &trans     &kp LG(LS(S))  &kp LS(LC(R))  &kp LC(R)      &trans     &kp MINUS  &kp KP_NUMBER_1  &kp KP_NUMBER_2  &kp KP_NUMBER_3  &kp PLUS         &trans  &trans
&trans  &kp LC(A)  &kp LS(S)      &kp LC(D)      &kp LC(LS(G))  &kp LC(G)  &kp DOT    &kp KP_NUMBER_4  &kp KP_NUMBER_5  &kp KP_NUMBER_6  &kp KP_NUMBER_0  &trans
&trans  &kp LC(Z)  &kp LC(X)      &kp LC(C)      &kp LC(V)      &kp LC(B)  &kp SLASH  &kp KP_NUMBER_7  &kp KP_NUMBER_8  &kp KP_NUMBER_9  &kp ASTERISK     &trans
                   &trans         &trans         &trans         &trans     &trans
            >;
        };

        CURSOR {
            bindings = <
&trans  &macro04  &macro05       &macro06          &trans      &trans      &trans    &kp LG(LEFT_ARROW)  &kp UP_ARROW    &kp LG(RIGHT_ARROW)  &trans   &trans  &trans
&trans  &macro01  &macro02       &macro03          &trans      &trans      &kp HOME  &kp LEFT_ARROW      &kp DOWN_ARROW  &kp RIGHT_ARROW      &kp END  &trans
&trans  &trans    &kp LESS_THAN  &kp GREATER_THAN  &kp LS(N8)  &kp LS(N9)  &trans    &trans              &trans          &trans               &trans   &trans
                  &trans         &trans            &trans      &trans      &kp ENTER
            >;
        };

        FUNCTION {
            bindings = <
&trans  &trans            &trans            &trans            &trans            &trans            &trans      &trans  &kp LA(PRINTSCREEN)  &trans  &kp LC(LA(DELETE))  &trans  &trans
&trans  &kp LA(NUMBER_1)  &kp LA(NUMBER_2)  &kp LA(NUMBER_3)  &kp LA(NUMBER_4)  &kp LA(NUMBER_5)  &trans      &trans  &kp LS(LG(S))        &trans  &kp LC(LS(ESCAPE))  &trans
&trans  &trans            &trans            &trans            &trans            &trans            &kp C_MUTE  &trans  &trans               &trans  &kp LC(LA(INS))     &trans
                          &trans            &trans            &trans            &trans            &trans
            >;
        };

        SCROLL {
            bindings = <
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans
                &trans  &trans  &trans  &trans  &trans
            >;
        };

        WIRELESS {
            bindings = <
&trans  &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_SEL 4  &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_SEL 4    &trans  &trans
&trans  &trans        &trans        &trans        &trans        &trans        &trans        &trans        &trans        &trans        &trans          &trans
&trans  &trans        &trans        &trans        &trans        &trans        &trans        &trans        &trans        &trans        &bt BT_CLR_ALL  &trans
                      &trans        &trans        &trans        &trans        &bootloader
            >;
        };
    };
};
